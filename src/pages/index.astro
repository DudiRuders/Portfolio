---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="mx-auto max-w-6xl px-4 py-20 md:py-32 flex flex-col items-start text-left">
    
    <div class="flex flex-wrap items-center gap-3 mb-8">
      <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 px-3 py-1.5 text-xs font-medium text-slate-600 dark:text-slate-300 shadow-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
        Intelligent Automation
      </span>
      <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 px-3 py-1.5 text-xs font-medium text-slate-600 dark:text-slate-300 shadow-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        AI Systems
      </span>
    </div>

    <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-[1.1]">
      Automatyzuję <br class="hidden md:block" />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-500 to-cyan-500">
        marketing i biznes.
      </span>
    </h1>

    <p class="mt-6 max-w-2xl text-lg md:text-xl text-slate-600 dark:text-slate-400 leading-relaxed">
      Projektuję rozwiązania, które przyspieszają pracę zespołów. Od porządkowania danych i integracji API, po inteligentne raportowanie z wykorzystaniem AI. Mniej ręcznej pracy, zero błędów.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a href="#projekty" class="group relative inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-500 px-6 py-3.5 text-sm font-semibold text-white shadow-sm hover:bg-emerald-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-500 transition-all">
        Zobacz projekty
        <svg class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
      
      <a href="#kontakt" class="inline-flex items-center justify-center gap-2 rounded-xl border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 px-6 py-3.5 text-sm font-semibold text-slate-900 dark:text-white hover:bg-slate-50 dark:hover:bg-white/10 transition-colors">
        Napisz do mnie
      </a>
    </div>

  </section>
  <section id="projekty" class="mx-auto max-w-6xl px-4 py-20 border-t border-slate-200 dark:border-white/10">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 dark:text-white">Wybrane projekty</h2>
        <p class="mt-3 text-slate-600 dark:text-slate-400 max-w-2xl">
          Automatyzacje i architektura danych, które zbudowałem. Skupiam się na realnym efekcie biznesowym.
        </p>
      </div>
      <a href="https://github.com/dudiruders" target="_blank" rel="noreferrer" class="group flex items-center gap-2 text-sm font-semibold text-emerald-600 dark:text-emerald-400 hover:text-emerald-500 transition-colors">
        Zobacz więcej na GitHub
        <span class="group-hover:translate-x-1 transition-transform">→</span>
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      
      <article class="group relative flex flex-col items-start justify-between rounded-2xl border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 p-8 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div>
          <h3 class="font-bold text-xl text-slate-900 dark:text-white group-hover:text-emerald-500 transition-colors">ETL</h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
            Pipeline do normalizacji nazw, gramatur, skrótów i błędów w danych produktowych z wielu działów.
          </p>
          <div class="mt-6 flex flex-wrap gap-2 text-xs font-medium">
            <span class="rounded-md bg-slate-100 dark:bg-slate-800 px-2.5 py-1 text-slate-700 dark:text-slate-300">Python</span>
            <span class="rounded-md bg-slate-100 dark:bg-slate-800 px-2.5 py-1 text-slate-700 dark:text-slate-300">Pandas</span>
            <span class="rounded-md bg-slate-100 dark:bg-slate-800 px-2.5 py-1 text-slate-700 dark:text-slate-300">PostgreSQL</span>
          </div>
        </div>
        <a href="/Portfolio/etl" class="mt-8 text-sm font-semibold text-emerald-600 dark:text-emerald-400 inline-flex items-center gap-1">
          Case study <span class="group-hover:translate-x-1 transition-transform">→</span>
          <span class="absolute inset-0"></span>
        </a>
      </article>

      <article class="group relative flex flex-col items-start justify-between rounded-2xl border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 p-8 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div>
          <h3 class="font-bold text-xl text-slate-900 dark:text-white group-hover:text-emerald-500 transition-colors">Document-automation</h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
            Inteligentna automatyzacja dokumentów. Pobieranie danych, szablony, generowanie PDF i synchronizacja statusów.
          </p>
          <div class="mt-6 flex flex-wrap gap-2 text-xs font-medium">
            <span class="rounded-md bg-slate-100 dark:bg-slate-800 px-2.5 py-1 text-slate-700 dark:text-slate-300">n8n</span>
            <span class="rounded-md bg-slate-100 dark:bg-slate-800 px-2.5 py-1 text-slate-700 dark:text-slate-300">API</span>
            <span class="rounded-md bg-slate-100 dark:bg-slate-800 px-2.5 py-1 text-slate-700 dark:text-slate-300">Airtable</span>
          </div>
        </div>
        <a href="/Portfolio/document-automation" class="mt-8 text-sm font-semibold text-emerald-600 dark:text-emerald-400 inline-flex items-center gap-1">
          Case study <span class="group-hover:translate-x-1 transition-transform">→</span>
          <span class="absolute inset-0"></span>
        </a>
      </article>

      <article class="group relative flex flex-col items-start justify-between rounded-2xl border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 p-8 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div>
          <h3 class="font-bold text-xl text-slate-900 dark:text-white group-hover:text-emerald-500 transition-colors">Dashboard KPI</h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
            Jedno źródło prawdy. Raportowanie, alerty i trendy dla marketingu oraz zarządu w Metabase.
          </p>
          <div class="mt-6 flex flex-wrap gap-2 text-xs font-medium">
            <span class="rounded-md bg-slate-100 dark:bg-slate-800 px-2.5 py-1 text-slate-700 dark:text-slate-300">Metabase</span>
            <span class="rounded-md bg-slate-100 dark:bg-slate-800 px-2.5 py-1 text-slate-700 dark:text-slate-300">SQL</span>
            <span class="rounded-md bg-slate-100 dark:bg-slate-800 px-2.5 py-1 text-slate-700 dark:text-slate-300">PostgreSQL</span>
          </div>
        </div>
        <a href="/Portfolio/kpi" class="mt-8 text-sm font-semibold text-emerald-600 dark:text-emerald-400 inline-flex items-center gap-1">
          Case study <span class="group-hover:translate-x-1 transition-transform">→</span>
          <span class="absolute inset-0"></span>
        </a>
      </article>

<article class="group relative md:col-span-3 flex flex-col md:flex-row items-start md:items-center justify-between gap-8 rounded-3xl border border-emerald-500/30 bg-emerald-50 dark:bg-emerald-500/10 p-8 md:p-10 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden">
        
        <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-emerald-500/10 blur-3xl group-hover:bg-emerald-500/20 transition-all duration-500"></div>
        
        <div class="relative flex-1">
          <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-xs font-semibold text-emerald-700 dark:text-emerald-300 mb-4">
            ✨ Wyróżniony projekt
          </div>
          <h3 class="font-bold text-2xl md:text-3xl text-slate-900 dark:text-white group-hover:text-emerald-500 transition-colors">
            Dynamic Video Automation
          </h3>
          <p class="mt-3 text-base md:text-lg text-slate-600 dark:text-slate-300 leading-relaxed max-w-3xl">
            Programistyczne generowanie tysięcy spersonalizowanych spotów wideo (MP4) poprzez REST API i dynamiczne payloady JSON. Koniec z ręcznym montażem i błędami w cenach.
          </p>
          <div class="mt-6 flex flex-wrap gap-2 text-xs font-medium">
            <span class="rounded-md bg-white/60 dark:bg-slate-900/50 px-3 py-1.5 text-slate-700 dark:text-slate-300 backdrop-blur-sm">JSON Payload</span>
            <span class="rounded-md bg-white/60 dark:bg-slate-900/50 px-3 py-1.5 text-slate-700 dark:text-slate-300 backdrop-blur-sm">REST API</span>
            <span class="rounded-md bg-white/60 dark:bg-slate-900/50 px-3 py-1.5 text-slate-700 dark:text-slate-300 backdrop-blur-sm">Creative Automation</span>
          </div>
        </div>
        
        <div class="relative mt-2 md:mt-0 shrink-0">
          <a href="/video-automation" class="inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-500 px-6 py-4 text-sm font-bold text-white shadow-lg hover:bg-emerald-400 hover:scale-105 transition-all z-10 relative">
            Case study
            <svg class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="/Portfolio/video-automation" class="absolute inset-0 z-0"><span class="sr-only">Zobacz Case Study wideo</span></a>
        </div>
        
      </article>

    </div>
  </section>

  <section id="co-robie" class="mx-auto max-w-6xl px-4 py-20 border-t border-slate-200 dark:border-white/10">
    <div class="mb-12">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 dark:text-white">W czym pomagam</h2>
      <p class="mt-3 text-slate-600 dark:text-slate-400 max-w-2xl">
        Łączę systemy i buduję workflow, które oszczędzają czas. Podejście best-tool-for-the-job.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-3 md:grid-rows-2">
      
      <div class="md:col-span-2 rounded-3xl border border-emerald-500/30 bg-emerald-50 dark:bg-emerald-500/10 p-8">
        <h3 class="font-bold text-xl text-slate-900 dark:text-white flex items-center gap-3">
          <span class="text-2xl">✨</span> Integracja narzędzi AI
        </h3>
        <p class="mt-3 text-slate-600 dark:text-slate-300 leading-relaxed">
          Dobieram modele i narzędzia do zadania. Wdrażam asystentów, automatyzuję ekstrakcję informacji, klasyfikację danych, standaryzację promptów oraz generowanie treści. Łączę AI z procesami biznesowymi (Workflow Automation, Webhooki, API).
        </p>
      </div>

      <div class="rounded-3xl border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 p-8">
        <h3 class="font-bold text-lg text-slate-900 dark:text-white">Marketing Automation</h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Kampanie, harmonogramy, integracje API z SaaS. Redukcja ręcznych powtarzalnych czynności w zespole.
        </p>
      </div>

      <div class="rounded-3xl border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 p-8">
        <h3 class="font-bold text-lg text-slate-900 dark:text-white">ETL i czyszczenie danych</h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Łączenie danych z wielu źródeł w jeden użyteczny model. Skrypty Python/Pandas do czyszczenia i mapowania.
        </p>
      </div>

      <div class="rounded-3xl border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 p-8">
        <h3 class="font-bold text-lg text-slate-900 dark:text-white">Backend & Logika</h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Pisanie mikroserwisów (FastAPI/Django), webhooki do komunikacji między systemami, reguły scoringowe.
        </p>
      </div>

      <div class="rounded-3xl border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 p-8">
        <h3 class="font-bold text-lg text-slate-900 dark:text-white">Raportowanie & BI</h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Dashboardy i KPI dla zarządu w Metabase. Automatyczne raporty, powiadomienia i jedno źródło prawdy.
        </p>
      </div>

    </div>
  </section>
  <section id="stack" class="mx-auto max-w-6xl px-4 py-20 border-t border-slate-200 dark:border-white/10">
    <div class="mb-12">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 dark:text-white">Stack technologiczny</h2>
      <p class="mt-3 text-slate-600 dark:text-slate-400 max-w-2xl">
        Narzędzia to tylko środek do celu, ale dobrze jest wiedzieć, co mam w skrzynce.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <h3 class="font-bold text-lg text-slate-900 dark:text-white mb-4 flex items-center gap-2">
          <span class="text-emerald-500">⚡</span> Automatyzacja
        </h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-slate-700 dark:text-slate-300">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500/50"></span> n8n & Make & Zapier
          </li>
          <li class="flex items-center gap-3 text-slate-700 dark:text-slate-300">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500/50"></span> Webhooks & Integracje API
          </li>
          <li class="flex items-center gap-3 text-slate-700 dark:text-slate-300">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500/50"></span> Airtable & Smartsuite
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-bold text-lg text-slate-900 dark:text-white mb-4 flex items-center gap-2">
          <span class="text-emerald-500">💾</span> Backend & Dane
        </h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-slate-700 dark:text-slate-300">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500/50"></span> Python (Pandas, ETL)
          </li>
          <li class="flex items-center gap-3 text-slate-700 dark:text-slate-300">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500/50"></span> Django & FastAPI
          </li>
          <li class="flex items-center gap-3 text-slate-700 dark:text-slate-300">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500/50"></span> PostgreSQL & SQL
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-bold text-lg text-slate-900 dark:text-white mb-4 flex items-center gap-2">
          <span class="text-emerald-500">🛠️</span> Dev & Prezentacja
        </h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-slate-700 dark:text-slate-300">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500/50"></span> AI & LLMs (Prompt Engineering)
          </li>
          <li class="flex items-center gap-3 text-slate-700 dark:text-slate-300">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500/50"></span> Docker & GitHub Actions
          </li>
          <li class="flex items-center gap-3 text-slate-700 dark:text-slate-300">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500/50"></span> HTML / Tailwind / Astro
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section id="jak-pracuje" class="bg-slate-50 dark:bg-white/[0.02] border-y border-slate-200 dark:border-white/10">
    <div class="mx-auto max-w-6xl px-4 py-20">
      <div class="mb-16 max-w-2xl">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 dark:text-white">Jak pracuję</h2>
        <p class="mt-3 text-slate-600 dark:text-slate-400">
          Zamiast od razu pisać kod, zaczynam od zrozumienia problemu. Mój proces gwarantuje, że wdrażamy to, co naprawdę działa.
        </p>
      </div>

      <div class="relative border-l-2 border-slate-200 dark:border-white/10 ml-3 md:ml-6 space-y-12 pb-4">
        
        <div class="relative pl-8 md:pl-12">
          <div class="absolute -left-[9px] top-1 h-4 w-4 rounded-full bg-slate-200 dark:bg-slate-700 border-4 border-slate-50 dark:border-slate-950"></div>
          <h3 class="font-bold text-xl text-slate-900 dark:text-white">1. Analiza procesu</h3>
          <p class="mt-2 text-slate-600 dark:text-slate-400 leading-relaxed">Mapuję przepływ informacji, identyfikuję punkty bólu, wąskie gardła i sprawdzam jakość źródeł danych.</p>
        </div>

        <div class="relative pl-8 md:pl-12">
          <div class="absolute -left-[9px] top-1 h-4 w-4 rounded-full bg-slate-200 dark:bg-slate-700 border-4 border-slate-50 dark:border-slate-950"></div>
          <h3 class="font-bold text-xl text-slate-900 dark:text-white">2. Projekt rozwiązania</h3>
          <p class="mt-2 text-slate-600 dark:text-slate-400 leading-relaxed">Dobieram odpowiedni stack technologiczny, planuję architekturę workflow oraz bezpieczne integracje systemów.</p>
        </div>

        <div class="relative pl-8 md:pl-12">
          <div class="absolute -left-[9px] top-1 h-4 w-4 rounded-full bg-emerald-500 border-4 border-slate-50 dark:border-slate-950 shadow-[0_0_10px_rgba(16,185,129,0.4)]"></div>
          <h3 class="font-bold text-xl text-slate-900 dark:text-white">3. Implementacja <span class="text-emerald-500 ml-2 text-sm font-normal uppercase tracking-wider">Core</span></h3>
          <p class="mt-2 text-slate-600 dark:text-slate-400 leading-relaxed">Tworzę rozwiązania backendowe i automatyzacyjne, kierując się zasadą "best-tool-for-the-job". Buduję logikę błędów i weryfikacji.</p>
        </div>

        <div class="relative pl-8 md:pl-12">
          <div class="absolute -left-[9px] top-1 h-4 w-4 rounded-full bg-slate-200 dark:bg-slate-700 border-4 border-slate-50 dark:border-slate-950"></div>
          <h3 class="font-bold text-xl text-slate-900 dark:text-white">4. Raportowanie & Dokumentacja</h3>
          <p class="mt-2 text-slate-600 dark:text-slate-400 leading-relaxed">Tworzę dashboardy KPI wspierające decyzje biznesowe. Dostarczam README, instrukcje i checklisty wdrożeń dla zespołu.</p>
        </div>

      </div>
    </div>
  </section>

  <section id="kontakt" class="mx-auto max-w-4xl px-4 py-24 text-center">
    <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-slate-900 dark:text-white">
      Gotowy na optymalizację?
    </h2>
    <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
      Porozmawiajmy o tym, jak inteligentna automatyzacja i AI mogą przyspieszyć procesy w Twojej firmie.
    </p>
    
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="mailto:mateusz.wienskowski@onet.pl" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-500 px-8 py-4 text-base font-semibold text-white shadow-sm hover:bg-emerald-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-500 transition-all">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        Napisz email
      </a>
      
      <a href="/oferta.pdf" rel="noreferrer" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-xl border-2 border-slate-200 dark:border-white/10 bg-transparent px-8 py-4 text-base font-semibold text-slate-900 dark:text-white hover:bg-slate-50 dark:hover:bg-white/5 transition-all">
        <svg class="h-5 w-5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        Pobierz ofertę (PDF)
      </a>
