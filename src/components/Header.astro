<header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/70 backdrop-blur-md">
  <div class="mx-auto max-w-6xl px-4 py-3 flex items-center justify-between">
    <a href="/#top" class="font-semibold tracking-tight">
      <span class="text-slate-200">Mateusz Wienskowski</span><span class="text-slate-400">/portfolio</span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm text-slate-300">
      <a class="hover:text-white transition-colors" href="/#projekty">Projekty</a>
      <a class="hover:text-white transition-colors" href="/#stack">Stack</a>
      <a class="hover:text-white transition-colors" href="/#jak-pracuje">Jak pracuję</a>
      <a class="hover:text-white transition-colors" href="/#kontakt">Kontakt</a>
    </nav>

    <div class="flex items-center gap-2">
      <button id="themeBtn" class="rounded-xl border border-white/10 px-3 py-1.5 text-sm text-slate-200 hover:bg-white/5 transition-colors" type="button">
        Tryb: <span id="themeLabel">ciemny</span>
      </button>
      <a href="/#kontakt" class="rounded-xl bg-emerald-400 text-slate-950 px-3 py-1.5 text-sm font-semibold hover:bg-emerald-300 transition-colors">
        Napisz
      </a>
    </div>
  </div>
</header>

<script>
  // Ten skrypt podepnie kliknięcie w przycisk zmiany motywu.
  const btn = document.getElementById('themeBtn');
  const label = document.getElementById('themeLabel');

  if (btn && label) {
    btn.addEventListener('click', () => {
      const current = localStorage.getItem('theme') || 'dark';
      const newTheme = current === 'dark' ? 'light' : 'dark';
      
      // Funkcja applyTheme jest w BaseLayout
      window.applyTheme(newTheme);
      
      label.textContent = newTheme === 'dark' ? 'ciemny' : 'jasny';
    });
  }
</script>