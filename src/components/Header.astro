<header class="sticky top-0 z-50 border-b border-slate-200 dark:border-white/10 bg-white/80 dark:bg-slate-950/80 backdrop-blur-md">
  <div class="mx-auto max-w-6xl px-4 py-3 flex items-center justify-between">
    <a href="/Portfolio/" class="font-semibold tracking-tight">
      <span class="text-slate-900 dark:text-slate-200">Mateusz Wienskowski</span><span class="text-slate-500 dark:text-slate-400">/portfolio</span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-600 dark:text-slate-300">
      <a class="hover:text-emerald-500 dark:hover:text-white transition-colors" href="/Portfolio/#projekty">Projekty</a>
      <a class="hover:text-emerald-500 dark:hover:text-white transition-colors" href="/Portfolio/#stack">Stack</a>
      <a class="hover:text-emerald-500 dark:hover:text-white transition-colors" href="/Portfolio/#jak-pracuje">Jak pracuję</a>
      <a class="hover:text-emerald-500 dark:hover:text-white transition-colors" href="/Portfolio/#kontakt">Kontakt</a>
    </nav>

    <div class="flex items-center gap-3">
      <button id="themeBtn" class="flex items-center gap-2 rounded-xl border border-slate-300 dark:border-white/20 bg-slate-100 dark:bg-white/10 px-3 py-1.5 text-xs font-bold text-slate-700 dark:text-white hover:bg-slate-200 dark:hover:bg-white/20 transition-all" type="button">
        <span class="opacity-70">Tryb:</span>
        <span id="themeLabel">ciemny</span>
      </button>

      <a href="/Portfolio/#kontakt" class="rounded-xl bg-emerald-500 text-white dark:text-slate-950 px-4 py-1.5 text-sm font-bold hover:bg-emerald-400 transition-colors shadow-sm">
        Napisz
      </a>
    </div>
  </div>
</header>

<script is:inline>
  // Skrypt inicjujący i obsługujący zmianę motywu
  (function() {
    const btn = document.getElementById('themeBtn');
    const label = document.getElementById('themeLabel');

    function updateLabel(theme) {
      if (label) label.textContent = theme === 'dark' ? 'ciemny' : 'jasny';
    }

    if (btn && label) {
      // Pobieramy aktualny stan z localStorage (zsynchronizowany z BaseLayout)
      const currentTheme = localStorage.getItem('theme') || 'dark';
      updateLabel(currentTheme);

      btn.addEventListener('click', () => {
        const theme = localStorage.getItem('theme') || 'dark';
        const newTheme = theme === 'dark' ? 'light' : 'dark';
        
        // Wywołujemy funkcję zdefiniowaną globalnie w BaseLayout
        if (window.applyTheme) {
          window.applyTheme(newTheme);
          updateLabel(newTheme);
        }
      });
    }
  })();
</script>